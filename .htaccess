Options -Indexes
RewriteEngine On

# Redirect /admin and /admin/ to /admin/login
RewriteRule ^admin/?$ /SPARKIIT-certifcate/admin/login [R=302,L]

# Remove .php extension from URLs
# e.g. /verify → /verify.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^.]+)$ $1.php [L]

# Redirect any direct .php request to the clean URL
# e.g. /verify.php → /verify
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
